# Firebase Client (public — safe to expose)
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=outreach-cbn-2026.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=outreach-cbn-2026
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=outreach-cbn-2026.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id

# AI Provider (server-side only — NEVER expose to client)
AI_PROVIDER=openai
AI_API_KEY=sk-your-key-here
AI_MODEL=gpt-4o-mini

# WhatsApp Webhook Verification (server-side only)
WHATSAPP_VERIFY_TOKEN=your_verify_token
