rules_version = '2';

// CBN Outreach — Temporary permissive rules for initial setup
// TODO: Restore strict org-scoped rules after confirming data structure

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    match /organizations/{orgId} {
      allow read, write: if isSignedIn();
    }

    match /users/{userId} {
      allow read, write: if isSignedIn();
    }

    match /respondents/{respondentId} {
      allow read, write: if isSignedIn();
    }

    match /tickets/{ticketId} {
      allow read, write: if isSignedIn();

      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    match /categories/{docId} {
      allow read, write: if isSignedIn();
    }

    match /lead_sources/{docId} {
      allow read, write: if isSignedIn();
    }

    match /program_sources/{docId} {
      allow read, write: if isSignedIn();
    }

    match /interaction_outcomes/{docId} {
      allow read, write: if isSignedIn();
    }

    match /calls/{callId} {
      allow read, write: if isSignedIn();
    }

    match /system_config/{configId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /counters/{counterId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
